### APP ###
APP_ENV=dev
APP_DEBUG=1

### DATABASE ###
DB_HOST=db
DB_PORT=5432
DB_NAME=loans
DB_USER=user
DB_PASSWORD=password

### SECURITY ###
COOKIE_VALIDATION_KEY=super-secret-key-change-me

### POSTGRES (для docker) ###
POSTGRES_DB=${DB_NAME}
POSTGRES_USER=${DB_USER}
POSTGRES_PASSWORD=${DB_PASSWORD}