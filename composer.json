{
  "name": "example/car-ads-service",
  "description": "REST API and admin panel for car ads on Yii2 + PostgreSQL",
  "type": "project",
  "require": {
    "php": "^8.2",
    "yiisoft/yii2": "^2.0.53",
    "yiisoft/yii2-bootstrap5": "^2.0",
    "yiisoft/yii2-gii": "^2.2",
    "yiisoft/yii2-debug": "^2.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "app\\": ""
    }
  },
  "autoload-dev": {
    "psr-4": {
      "tests\\": "tests/"
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "php yii migrate --interactive=0"
    ],
    "test": "vendor/bin/phpunit --configuration phpunit.xml"
  }
}
