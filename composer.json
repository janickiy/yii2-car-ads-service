{
  "name": "app/yii2-car-ads-service",
  "description": "Car ads service on Yii2",
  "type": "project",
  "require": {
    "php": "^8.2",
    "yiisoft/yii2": "^2.0.54",
    "yiisoft/yii2-bootstrap5": "^2.0"
  },
  "require-dev": {
    "yiisoft/yii2-debug": "^2.1",
    "yiisoft/yii2-gii": "^2.2"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "autoload": {
    "psr-4": {
      "app\\": ""
    }
  },
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  }
}